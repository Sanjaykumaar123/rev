# =====================================================
# Digimation Flight 3.0 - Backend Environment Template
# Copy this file to .env and fill in your real values
# =====================================================

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Server Port (Render sets this automatically; use 5000 for local)
PORT=5000

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL=https://your-app.vercel.app

# SMTP Email Configuration (optional - for transactional emails)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM="Digimation Academy" <no-reply@digimation.com>
SMTP_TO=admin@digimation.com

# Node Environment
NODE_ENV=production
